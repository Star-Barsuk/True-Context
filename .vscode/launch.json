{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug true_context",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Debug/true_context",
            "args": ["--help"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake: build debug"
        },
        {
            "name": "Debug true_context (sanitizers)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug-sanitize/true_context",
            "args": ["--version"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "cmake: build sanitize"
        }
    ]
}
